{
  "name": "forgeclaw",
  "private": true,
  "version": "0.1.0",
  "description": "Multi-agent governance shell with autonomous GitHub operations, browser automation, and integrity enforcement.",
  "author": "DeviousDevv303 <towerslutz@gmail.com>",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "scripts": {
    "check:conflicts": "grep -rn '^<<<<<<< \\|^>>>>>>> \\|^=======$' src/ --include='*.ts' --include='*.tsx' && echo 'CONFLICT MARKERS FOUND' && exit 1 || exit 0",
    "prebuild": "npm run check:conflicts && npm run lint",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "setup:hooks": "node scripts/setupGitHooks.mjs",
    "test": "vitest --passWithNoTests",
    "test:run": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "@supabase/supabase-js": "^2.101.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.12",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^3.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "jsdom": "^26.1.0",
    "vite": "^8.0.1",
    "vitest": "^3.2.2"
  }
}
